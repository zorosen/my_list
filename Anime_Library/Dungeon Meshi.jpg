			.page-id-162707 .entry-title{
display:none;
}                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    |
| .top_posts_deck {
	margin-right: 0;
	margin-left: 0;
}

.top_posts {
	margin-right: 3px !important;
	margin-left: 3px !important;
}

.top_posts_url {
	color: #ffffff;
}

.top_posts_body {
	padding: 0;
	flex: none;
}

.top_post_title_wrap {
	position: absolute;
  bottom: 0px;
  width: 100%;
	background-color: #273138;
  opacity: 0.8;
}

.top_posts_title {
	color: #fff;
  font-family: montserrat,sans-serif;
  font-size: 18px;
  font-weight: 700;
	padding: 5px 10px 5px 10px
}

.top_posts_title a:hover {
	text-decoration: none;
	color: #007bff;
}

@media only screen and (max-width: 768px) {
	.top_posts {
		min-width: 100%;
	}
	
	.top_posts_deck {
		flex-direction: row;	
		width: 300px;
		margin-right: 312px;
	}
	
	.slider-container {
		overflow-x: scroll;
    display: flex;
	}
}

.btn-primary {
	background-color: #00bfff;
  border-color: #00bfff;
	padding: 0.5rem 1.75rem;
}

nav img {
	width: 400px !important;
}

@media only screen and (max-width: 768px) {
	nav img {
		width: 220px !important;
	}
}

.menu-search-icon {
	padding-top: 0;
	cursor: pointer;
}

.login-icon {
	cursor: pointer;
}

.main-navigation-desktop, .main-navigation-mobile {
	background-color: #273138;
	height: 60px;
	margin-left: -13px;
  margin-right: -13px;
}

.main-navigation-mobile {
	display: none;
}

.search-nav {
	height: 60px;
	margin-left: -13px;
  margin-right: -13px;
}

.search-nav .container {
	background-color: transparent !important;
}

.login-menu-button {
	display: none;
}

.site-footer {
	margin-left: -13px;
  margin-right: -13px;
}

.footer-copyright .container {
	background-color: #273138;
}

.slider-row, .card {
	background-color: transparent !important;
}

#mega-menu-wrap-menu-1 #mega-menu-menu-1>li.mega-menu-megamenu>ul.mega-sub-menu li.mega-menu-column>ul.mega-sub-menu>li.mega-menu-item>a.mega-menu-link {
	color: #00bfff !important;
}

@media only screen and (max-width: 768px) {
	.navbar-collapse {
		background-color: #273138;
  	margin-top: 28px;
	}
	
	.main-navigation-mobile {
		display: flex;
	}
	
	.main-navigation-desktop {
		display: none;
	}
	
	.mega-menu-horizontal {
		height: 100vh !important;
	}
	
	.login-menu-button {
		display: block;
	}
	
	.login-menu-button {
		margin: auto;
		margin-top: 20px;
    padding-left: 100px;
    padding-right: 100px;
    padding-top: 5px;
    padding-bottom: 5px;
    background-color: #00bfff;
    border-radius: 10px;
		color: #ffffff;
	}
	
	.mega-menu-item {
		border-bottom: 2px solid #d6cccc !important;
		padding: 6px !important;
	}
}

